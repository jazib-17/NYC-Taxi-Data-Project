train_dat$dropoff_latitude, train_dat$dropoff_longitude)
test_dat$distance  <- haversine(test_dat$pickup_latitude,  test_dat$pickup_longitude,
test_dat$dropoff_latitude,  test_dat$dropoff_longitude)
# Hour of day (0–23)
